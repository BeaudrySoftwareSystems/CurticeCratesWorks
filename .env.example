# ============================================================================
# Curtis Crates Inventory Management — environment variables
# Copy to .env.local for local development. Set in Vercel for production.
# ============================================================================

# --- Database (Neon Postgres) -----------------------------------------------
# Connection string from your Neon project. Use a dev branch for local work.
# Format: postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# --- Auth (Auth.js v5 / NextAuth v5) ---------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated list of staff email addresses allowed to sign in.
# Example: justin@example.com,jaden@example.com
# Removing an email + redeploying revokes access on the next request
# (revocation latency ~30s, bounded above by 24h JWT TTL).
STAFF_ALLOWLIST=

# --- Email (magic-link transport) ------------------------------------------
# v1 uses Resend for magic-link delivery. Sign up at resend.com and create a
# verified sending domain. AUTH_RESEND_KEY is the API key.
AUTH_RESEND_KEY=

# Email address that magic links are sent FROM. Must be on a domain you've
# verified in Resend. Example: noreply@curtiscrates.com
EMAIL_FROM=

# --- Vercel Blob (Unit 6, Phase 2) -----------------------------------------
# Read/write token from your Vercel Blob store. The @vercel/blob SDK reads
# this automatically from the env. Required for the photo upload pipeline.
BLOB_READ_WRITE_TOKEN=

# Public hostname of your Vercel Blob store, no trailing slash. Used by the
# Blob gateway to compose stable photo URLs from stored pathnames.
# Example: https://abc123.public.blob.vercel-storage.com
BLOB_STORE_BASE_URL=

# --- Optional: Logging ------------------------------------------------------
# LOG_LEVEL controls Pino logger verbosity. Defaults to "info".
# Values: trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
